{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@silver/ui": ["./packages/ui/src/index.ts"],
      "@silver/ui/*": ["./packages/ui/src/*"],
      "@silver/types": ["./packages/types/src/index.ts"],
      "@silver/types/*": ["./packages/types/src/*"],
      "@silver/db": ["./packages/db/src/index.ts"],
      "@silver/db/*": ["./packages/db/src/*"],
      "@silver/auth": ["./packages/auth/src/index.ts"],
      "@silver/auth/*": ["./packages/auth/src/*"],
      "@silver/capture": ["./packages/capture/src/index.ts"],
      "@silver/capture/*": ["./packages/capture/src/*"],
      "@silver/linear": ["./packages/linear/src/index.ts"],
      "@silver/linear/*": ["./packages/linear/src/*"],
      "@silver/ai": ["./packages/ai/src/index.ts"],
      "@silver/ai/*": ["./packages/ai/src/*"],
      "@silver/config": ["./packages/config/src/index.ts"],
      "@silver/config/*": ["./packages/config/src/*"]
    }
  }
}
